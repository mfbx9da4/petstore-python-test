{
  "name": "openapi",
  "version": "0.0.5",
  "author": "Speakeasy",
  "type": "module",
  "tshy": {
    "sourceDialects": [
      "openapi/source"
    ],
    "exports": {
      ".": "./src/index.ts",
      "./package.json": "./package.json",
      "./types": "./src/types/index.ts",
      "./models/errors": "./src/models/errors/index.ts",
      "./models": "./src/models/index.ts",
      "./*.js": "./src/*.ts",
      "./*": "./src/*.ts"
    }
  },
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "https://github.com/mfbx9da4/petstore-python-test.git",
    "directory": "dist/typescript"
  },
  "scripts": {
    "lint": "eslint --cache --max-warnings=0 src",
    "build": "tshy",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    
  },
  "devDependencies": {
    "@eslint/js": "^9.26.0",
    "eslint": "^9.26.0",
    "globals": "^15.14.0",
    "tshy": "^2.0.0",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.26.0"
  },
  "dependencies": {
    "zod": "^3.25.65 || ^4.0.0"
  }
}
